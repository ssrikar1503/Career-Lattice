# Career Pathways Platform — Pipeline environment variables
# Copy this file to .env and fill in real values.

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from Supabase project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Anthropic Claude (primary — used for extraction + matching)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (optional fallback — used when Claude hits rate limits)
# Get free key: https://aistudio.google.com/app/apikey
# Free tier: 1,500 requests/day — generous for backup
GEMINI_API_KEY=AIza...
