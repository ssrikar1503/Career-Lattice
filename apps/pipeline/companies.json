    "tenant":   "(workday only) subdomain, e.g. 'intel' in intel.wd1.myworkdayjobs.com",
    "wd":       "(workday only) datacenter number, e.g. 1 or 5 from .wd1. or .wd5.",
    "site":     "(workday only) site path, e.g. 'External' or 'NVIDIAExternalCareerSite'"
  },

